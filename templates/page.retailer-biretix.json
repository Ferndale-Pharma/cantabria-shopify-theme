    "multicolumn_html_MMRew6": {
      "type": "multicolumn-html",
      "blocks": {
        "column_4cJDMm": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/tri-active.jpg",
            "title": "",
            "text": "<h3 class=\"inline-richtext\">BIRETIX<br> Tri-Active Anti-Blemish Gel</h3><p style=\"margin-top: 1rem;\">Clinically proven to target multiple causes of acne-prone skin, helping exfoliate and unclog pores, control excess sebum and acne-causing bacteria while reducing visible redness. Clinically proven to reduce blemished by 76% and blackheads by 61% in 28 days.<sup>1</sup></p>",
            "link_label": "",
            "link": ""
          }
        },
        "column_hgGPxQ": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/double-correction.jpg",
            "title": "",
            "text": "<h3 class=\"inline-richtext\">BIRETIX<br> Double Correction Serum</h3><p style=\"margin-top: 1rem;\">A high-performance, dual-action solution designed for adult skin prone to acne and blemishes. Clinically proven to help regulate excess sebum, reduce shine and minimise the appearance of pores in just 14 days.<sup>5</sup></p>",
            "link_label": "",
            "link": ""
          }
        },
        "column_knECVK": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/isorepair-cleanser.jpg",
            "title": "",
            "text": "<h3 class=\"inline-richtext\">BIRETIX<br> Isorepair Creamy Cleanser</h3><p style=\"margin-top: 1rem;\">A soothing daily face wash designed for dry, sensitive and acne-prone skin, and to support those undergoing prescription retinoid treatments. Clinically tested for high tolerance, with 89% of users reporting healthier-looking skin after use.<sup>6</sup></p>",
            "link_label": "",
            "link": ""
          }
        },
        "column_XkXjKk": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/biretix-isorepair-cream-layflat.jpg",
            "title": "",
            "text": "<h3 class=\"inline-richtext\">BIRETIX<br> Isorepair Cream</h3><p style=\"margin-top: 1rem;\">A comprehensive barrier-repair rcream designed to support dry and sensitive acne-prone skin as well as skin undergoing prescription retinoid treatment. Clinically proven to support skin hydration, reducing transepidermal water loss (TEWL) by 46%.<sup>7</sup></p>",
            "link_label": "",
            "link": ""
          }
        }
      },
